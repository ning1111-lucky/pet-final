# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
GEMINI_MODEL="gemini-2.5-flash"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# POLLINATIONS_KEY: Required for Day 7 weekly pet image generation.
# For local development, put the real value in `.env.local`.
POLLINATIONS_KEY="YOUR_POLLINATIONS_KEY"

# LEONARDO_API_KEY: Required for Day 7 Leonardo image guidance generation.
# For local development, put the real value in `.env.local`.
LEONARDO_API_KEY="YOUR_LEONARDO_API_KEY"
LEONARDO_MODEL_ID=""
LEONARDO_API_BASE_URL=""

# Spotify Web API OAuth credentials.
# Redirect URI should point to /api/spotify/callback on your deployed domain.
SPOTIFY_CLIENT_ID="YOUR_SPOTIFY_CLIENT_ID"
SPOTIFY_CLIENT_SECRET="YOUR_SPOTIFY_CLIENT_SECRET"
SPOTIFY_REDIRECT_URI="http://localhost:3000/api/spotify/callback"

# Last.fm public API key for recent track and artist tag lookup.
LASTFM_API_KEY="YOUR_LASTFM_API_KEY"
